<?xml version="1.0"?>
<?mso-application progid="Excel.Sheet"?>
<Workbook xmlns="urn:schemas-microsoft-com:office:spreadsheet" xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:x="urn:schemas-microsoft-com:office:excel" xmlns:ss="urn:schemas-microsoft-com:office:spreadsheet">
  <Styles>
    <Style ss:ID="Header"><Font ss:Bold="1"/><Interior ss:Color="#D9EAF7" ss:Pattern="Solid"/></Style>
    <Style ss:ID="Text"><NumberFormat ss:Format="@"/></Style>
  </Styles>
  <Worksheet ss:Name="HoDan">
    <Table>
      <Row>
        <Cell ss:StyleID="Header"><Data ss:Type="String">Mã hộ</Data></Cell>
        <Cell ss:StyleID="Header"><Data ss:Type="String">Tên chủ hộ</Data></Cell>
        <Cell ss:StyleID="Header"><Data ss:Type="String">Địa chỉ</Data></Cell>
